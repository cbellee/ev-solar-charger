{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "FUNCTIONS_WORKER_RUNTIME": "Custom",
    "TESLA_CLIENT_ID": "your-client-id",
    "TESLA_CLIENT_SECRET": "your-client-secret-or-keyvault-reference",
    "TESLA_REDIRECT_URI": "https://tesla.bellee.net/oauth/callback",
    "TESLA_REGION": "na",
    "TESLA_SCOPE": "openid offline_access vehicle_device_data vehicle_cmds vehicle_charging_cmds",
    "TESLA_PUBLIC_KEY_PEM": "-----BEGIN PUBLIC KEY-----\\n...\\n-----END PUBLIC KEY-----",
    "OAUTH_STATE_HMAC_KEY": "replace-with-a-long-random-secret",
    "KEY_VAULT_URI": "https://your-vault-name.vault.azure.net/",
    "TESLA_REFRESH_TOKEN_SECRET_NAME": "tesla-refresh-token"
  }
}
