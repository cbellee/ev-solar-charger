# Required
SUNGROW_HOST=192.168.1.100
TESLA_CLIENT_ID=your-client-id
TESLA_CLIENT_SECRET=your-client-secret
# Optional at first startup if token file exists; otherwise required until OAuth callback is completed
TESLA_REFRESH_TOKEN=
TESLA_REDIRECT_URI=https://tesla.bellee.net/auth/tesla/callback
TESLA_VIN=5YJ3E1EA0RF000000
TESLA_TEST_MODE=true

# Optional (defaults shown)
SUNGROW_PORT=8082
TESLA_PRIVATE_KEY_PATH=/secrets/fleet-key.pem
TESLA_PUBLIC_KEY_PEM_PATH=/secrets/com.tesla.3p.public-key.pem
TESLA_REGION=na
TESLA_SCOPE=openid offline_access vehicle_device_data vehicle_cmds vehicle_charging_cmds
OAUTH_STATE_HMAC_KEY=change-me-random-long-secret
TESLA_TOKEN_PATH=/data/tesla-refresh-token
POLL_INTERVAL_SECONDS=10
MIN_CHARGE_AMPS=5
MAX_CHARGE_AMPS=32
LINE_VOLTAGE=240
DEADBAND_POLLS=3
WAKE_THRESHOLD_POLLS=6
HTTP_AUTH_USER=admin
HTTP_AUTH_PASSWORD=change-me
HTTP_PORT=8080
TLS_ENABLED=false
TLS_DOMAIN=tesla.bellee.net
TLS_CERT_DIR=/data/autocert
TLS_PORT=8443
HTTP_CHALLENGE_PORT=8081
LOG_LEVEL=info
DB_PATH=/data/solar-ev-charger.db
DB_RETENTION_DAYS=365

# OpenTelemetry (optional — omit for stdout)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://collector:4318
# OTEL_SERVICE_NAME=solar-ev-charger
