# Required
SUNGROW_HOST=192.168.1.100
TESLA_CLIENT_ID=your-client-id
TESLA_CLIENT_SECRET=your-client-secret
# Optional at first startup if token file exists; otherwise required until OAuth callback is completed
TESLA_REFRESH_TOKEN=
TESLA_REDIRECT_URI=https://ev.bellee.net/auth/tesla/callback
TESLA_VIN=5YJ3E1EA0RF000000
TESLA_TEST_MODE=true

# Optional (defaults shown)
SUNGROW_PORT=8082
TESLA_PRIVATE_KEY_PATH=/secrets/fleet-key.pem
TESLA_PUBLIC_KEY_PEM_PATH=/secrets/com.tesla.3p.public-key.pem
TESLA_REGION=na
TESLA_SCOPE=openid offline_access vehicle_device_data vehicle_cmds vehicle_charging_cmds
OAUTH_STATE_HMAC_KEY=change-me-random-long-secret
TESLA_TOKEN_PATH=/data/tesla-refresh-token

# Optional Fleet Telemetry bridge. Set a shared secret to enable the public
# bridge endpoint; leave FLEET_TELEMETRY_STALE_AFTER_SECONDS=0 to disable the
# stream cache, or set ~180 when telemetry updates are flowing reliably.
FLEET_TELEMETRY_SHARED_SECRET=
FLEET_TELEMETRY_STALE_AFTER_SECONDS=0
# Optional in-process Fleet Telemetry MQTT bridge. Point these at the Tesla
# Fleet Telemetry MQTT backend to refresh the controller cache directly.
FLEET_TELEMETRY_MQTT_BROKER=
FLEET_TELEMETRY_MQTT_TOPIC_BASE=telemetry
FLEET_TELEMETRY_MQTT_CLIENT_ID=
FLEET_TELEMETRY_MQTT_USERNAME=
FLEET_TELEMETRY_MQTT_PASSWORD=

# Tesla Vehicle Command Protocol (required for 2021+ Model 3/Y/S/X).
# When set, charge_start/charge_stop/set_charging_amps/wake_up are routed
# through the tesla-http-proxy sidecar which signs commands with fleet-key.pem.
# Set by docker-compose; leave blank for local dev or test mode.
TESLA_COMMAND_BASE=
TESLA_PROXY_CA_FILE=

# Control loop
POLL_INTERVAL_SECONDS=10
MIN_CHARGE_AMPS=5
MAX_CHARGE_AMPS=32
LINE_VOLTAGE=240
DEADBAND_POLLS=3
AMPS_CHANGE_THRESHOLD=2
AMPS_ADJUST_INTERVAL_SECONDS=60

# Tesla wake & polling cost controls
WAKE_THRESHOLD_POLLS=6
WAKE_RETRY_INTERVAL_SECONDS=300
PLUGGED_IN_STALE_AFTER_SECONDS=86400
WAKE_ALLOWED_START_HOUR=8
WAKE_ALLOWED_END_HOUR=19
WAKE_TIMEZONE=Australia/Sydney
TESLA_CHARGING_POLL_SECONDS=300
TESLA_IDLE_POLL_SECONDS=1800

# Command rate limiting (reduces Fleet API command spend)
CHARGE_START_RETRY_SECONDS=120
COMMAND_FAILURE_BACKOFF_SECONDS=300

# HTTP server
HTTP_HOST=127.0.0.1
HTTP_PORT=8080

# Microsoft Entra ID auth (validates ID tokens on /api/* and /events).
# The app must be registered in Entra as a Single-page application with
# https://<your-host>/ and http://localhost:5173/ in its redirect URIs.
ENTRA_TENANT_ID=0cd02bb5-3c24-4f77-8b19-99223d65aa67
ENTRA_CLIENT_ID=a34c5444-abcb-47ac-9974-f95cf7c596cb
# Optional comma-separated list of allowed user object IDs (oid claim).
# Leave empty to allow any user from the configured tenant.
ENTRA_ALLOWED_OIDS=

TLS_ENABLED=false
TLS_DOMAIN=ev.bellee.net
TLS_CERT_DIR=/data/autocert
TLS_PORT=8443
HTTP_CHALLENGE_PORT=8081

# Logging & storage
LOG_LEVEL=info
DB_PATH=/data/solar-ev-charger.db
DB_RETENTION_DAYS=365

# OpenTelemetry (optional — omit for stdout)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://collector:4318
# OTEL_SERVICE_NAME=solar-ev-charger
